{
  "name": "cacsms-studio",
  "private": true,
  "version": "0.1.0",
  "description": "CACSMS Autonomous Media Studio domain-driven monorepo.",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @cacsms/web dev -- --hostname 0.0.0.0 --port 3008",
    "build": "turbo build",
    "build:web": "pnpm --filter @cacsms/web build",
    "start": "node server.js",
    "start:iis-node": "set NODE_ENV=production&& set PORT=3018&& set CACSMS_PUBLIC_PORT=3008&& node server.js",
    "start:web": "pnpm --filter @cacsms/web start",
    "iis:install": "powershell -ExecutionPolicy Bypass -File infrastructure/deployment/iis/install-iis-site.ps1",
    "iis:verify": "powershell -ExecutionPolicy Bypass -File infrastructure/deployment/iis/verify-iis-site.ps1",
    "db:verify": "powershell -ExecutionPolicy Bypass -File infrastructure/database/verify-mssql-connection.ps1",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File infrastructure/database/migrate-mssql.ps1",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  }
}
